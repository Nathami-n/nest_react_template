{
  "extends": "@repo/typescript-config/nestjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react",
    "paths": {
      "@api/*": ["./apps/api/src/*"],
      "@app/common": ["./libs/common/src"],
      "@app/common/*": ["./libs/common/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "libs/**/*.ts",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
